# ==========================================
# DISPLAY HARDWARE
# ==========================================
# IP of the Indicatrr Pi Zero running the OLED display
INDICATRR_FRAME_ADDRESS=tcp://<indicatrr-ip>:5555
HARDWARE_EVENTS_BIND_ADDRESS=tcp://0.0.0.0:5556

# ==========================================
# SWITCHRR ROUTING
# ==========================================
MODE_EVENTS_BIND_ADDRESS=tcp://0.0.0.0:5557
FRAME_SEND_HWM=5
LOG_LEVEL=INFO
# One entry per toggle position (1–4). First entry with "default":true is activated on startup.
MODE_REGISTRY=[{"mode_name":"uk_tdd","display_name":"Train Departures","toggle_position":1,"frame_bind_address":"tcp://0.0.0.0:5600","default":true},{"mode_name":"powrr","display_name":"Power","toggle_position":2,"frame_bind_address":"tcp://0.0.0.0:5601"},{"mode_name":"mode3","display_name":"Mode 3","toggle_position":3,"frame_bind_address":"tcp://0.0.0.0:5602"},{"mode_name":"mode4","display_name":"Mode 4","toggle_position":4,"frame_bind_address":"tcp://0.0.0.0:5603"}]

# ==========================================
# DISPLAY DIMENSIONS (shared across modes)
# ==========================================
DISPLAY_WIDTH=256
DISPLAY_HEIGHT=64

# ==========================================
# POWRR — MQTT (Home Assistant broker)
# ==========================================
MQTT_HOST=<mqtt-broker-ip>
MQTT_PORT=1883
MQTT_USERNAME=<username>
MQTT_PASSWORD=<password>
GRAPH_WINDOW_SECONDS=3600
